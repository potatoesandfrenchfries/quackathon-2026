# ================================================================
# Buddy Backend — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ================================================================

# --- Supabase ---
SUPABASE_URL=https://ewyenqtrkdzgckrncwvb.supabase.co
SUPABASE_ANON_KEY=sb_publishable_mYH-9p1vW-PHnVwXTPtmLQ__WPCv1SZ

# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Get from: Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here

# --- Anthropic ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Pinecone ---
# Get from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=buddy-finance

# --- Redis (Upstash) ---
# Get from: https://console.upstash.com (free tier)
# Format: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
